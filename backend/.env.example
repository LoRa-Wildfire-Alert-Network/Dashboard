# External API for live LoRa telemetry
LIVE_URL=https://example.com/api/live

# CORS allowed origins
ALLOWED_ORIGINS=*

# SQLite database filename
DB_NAME=lora.db

# Clerk authentication
CLERK_JWT_ISSUER=https://your-clerk-instance.clerk.accounts.dev
CLERK_SECRET_KEY=
CLERK_API_BASE=https://api.clerk.com

# Alert email configuration
ALERT_EMAIL=
ALERT_PASS=

# SMTP settings
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=465

# Alert worker settings
ALERT_WORKERS=1
ALERTS_ENABLE_WORKERS=1
ALERT_POLL_SECONDS=1.0
ALERT_CLAIM_TTL_SECONDS=60
ALERT_PREF_COOLDOWN_SECONDS=300